Cfilter id=%27noiseFilter%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.65%27 numOctaves=%273%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url%28%23noiseFilter%29%27 opacity=%270.03%27/%3E%3C/svg%3E\"); padding-top: env(safe-area-inset-top, 0px); }\n.landing-container { max-width: 64rem; margin: 0px auto; min-height: 100vh; padding: 2rem 1.5rem; display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }\n.logo-container { width: 180px; height: 180px; border-radius: 1.5rem; overflow: hidden; box-shadow: rgba(248, 200, 220, 0.5) 0px 10px 40px -10px; transition: transform 0.3s, box-shadow 0.3s; }\n.logo-container:hover { transform: scale(1.02); box-shadow: rgba(248, 200, 220, 0.6) 0px 15px 50px -10px; }\n.logo-container img { width: 100%; height: 100%; object-fit: cover; }\n.links-section { width: 100%; display: flex; flex-direction: column; gap: 0.75rem; }\n.links-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; }\n@media (min-width: 640px) {\n  .links-grid { grid-template-columns: repeat(2, 1fr); }\n}\n.section-title { font-family: \"Playfair Display\", serif; font-size: 1.125rem; font-weight: 600; color: rgb(51, 51, 51); margin-bottom: 0.25rem; padding-left: 0.25rem; }\n.icon-ebay { color: rgb(229, 50, 56); }\n.icon-poshmark { color: rgb(127, 3, 83); }\n.icon-mercari { color: rgb(255, 2, 17); }\n.icon-depop { color: rgb(255, 35, 0); }\n.icon-facebook { color: rgb(24, 119, 242); }\n.icon-tiktok { color: rgb(0, 0, 0); }\n.form-container { max-width: 36rem; margin: 0px auto; padding: 2rem 1.5rem; }\n.form-header { text-align: center; margin-bottom: 2rem; }\n.form-title { font-family: \"Playfair Display\", serif; font-size: 2rem; font-weight: 700; color: rgb(51, 51, 51); margin-bottom: 0.5rem; }\n.form-subtitle { font-size: 1rem; color: rgb(102, 102, 102); }\n.form-card { background: white; border-radius: 1.5rem; padding: 2rem; box-shadow: rgba(248, 200, 220, 0.25) 0